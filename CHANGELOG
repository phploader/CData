#Update DB 2.09 => 2.10
Bei den folgenden Spalten muss integer zur text geändert werden!
wp_data - parent_path_hash
wp_data_att - parent_path_hash
wp_data_cache -parent_path_hash, path_hash

#Update DB 2.0x => 2.09
BEGIN;
CREATE TABLE "adminer_wp_data" (
  "id" text NOT NULL,
  "type_id" text NOT NULL,
  "parent_path_hash" integer NOT NULL,
  "parent_type_id" text NOT NULL,
  "parent_data_id" text NOT NULL,
  "utimestamp" integer NULL DEFAULT (cast(strftime('%s', 'now') as int)),
  "itimestamp" integer NULL DEFAULT (cast(strftime('%s', 'now') as int)),
  PRIMARY KEY ("id", "type_id", "parent_path_hash")
);
INSERT INTO "adminer_wp_data" ("id", "type_id", "parent_path_hash", "parent_type_id", "parent_data_id", "utimestamp", "itimestamp") SELECT "id", "type_id", "path_hash", "parent_type_id", "parent_data_id", "utimestamp", "itimestamp" FROM "wp_data";
DROP TABLE "wp_data";
ALTER TABLE "adminer_wp_data" RENAME TO "wp_data";
CREATE INDEX "wp_data_parent_type_id_parent_data_id" ON "wp_data" ("parent_type_id", "parent_data_id");
CREATE INDEX "wp_data_id" ON "wp_data" ("id");
CREATE INDEX "wp_data_type_id" ON "wp_data" ("type_id");
CREATE INDEX "wp_data_utimestamp" ON "wp_data" ("utimestamp");
CREATE INDEX "wp_data_to_type_id" ON "wp_data" ("parent_type_id");
CREATE INDEX "wp_data_id_type_id" ON "wp_data" ("id", "type_id");
CREATE INDEX "wp_data_id_type_id_to_type_id" ON "wp_data" ("id", "type_id");
CREATE INDEX "wp_data_id_path_hash" ON "wp_data" ("parent_path_hash");
COMMIT;

BEGIN;
CREATE TABLE "adminer_wp_data_att" (
  "id" text COLLATE 'BINARY' NOT NULL,
  "type_id" text NOT NULL,
  "parent_path_hash" integer NOT NULL,
  "attribute_id" text NOT NULL,
  "value" text NULL,
  "sort" numeric NULL,
  "utimestamp" integer NULL DEFAULT (cast(strftime('%s', 'now') as int)),
  "itimestamp" integer NULL DEFAULT (cast(strftime('%s', 'now') as int)),
  PRIMARY KEY ("id", "type_id", "parent_path_hash", "attribute_id")
);
INSERT INTO "adminer_wp_data_att" ("id", "type_id", "parent_path_hash", "attribute_id", "value", "sort", "utimestamp", "itimestamp") SELECT "id", "type_id", "path_hash", "attribute_id", "value", "sort", "utimestamp", "itimestamp" FROM "wp_data_att";
DROP TABLE "wp_data_att";
ALTER TABLE "adminer_wp_data_att" RENAME TO "wp_data_att";
CREATE INDEX "wp_data_att_value_hash" ON "wp_data_att" ("sort");
CREATE INDEX "wp_data_att_id_type_id_attribute_id" ON "wp_data_att" ("id", "type_id", "attribute_id");
CREATE INDEX "wp_data_att_id_type_id" ON "wp_data_att" ("id", "type_id");
CREATE INDEX "wp_data_att_attribute_id" ON "wp_data_att" ("attribute_id");
CREATE INDEX "wp_data_att_type_id" ON "wp_data_att" ("type_id");
CREATE INDEX "wp_data_att_id" ON "wp_data_att" ("id");
CREATE INDEX "wp_data_att_utimestamp" ON "wp_data_att" ("utimestamp");
CREATE INDEX "wp_data_att_path_hash" ON "wp_data_att" ("parent_path_hash");
COMMIT;

